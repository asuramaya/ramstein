#!/usr/bin/env python3
"""ramsteind — the memory demon: owns the truth about bytes alive.

Polls /proc/meminfo and /proc/pressure/memory every tick, computes an
EWMA burn rate of available-memory consumption and an ETA-to-OOM under
current pressure, and publishes status.json for the CLI and the GNOME
pill. The daemon is the only privileged actor; the CLI and pill only
read status and poke the control socket.

stdlib only, by constitution.
"""

import argparse
import json
import math
import os
import signal
import socket
import sqlite3
import struct
import subprocess
import threading
import time

VERSION = "0.5.0"

RUNTIME_DIR = os.environ.get("RAMSTEIN_RUNTIME_DIR", "/run/ramstein")
STATUS_PATH = os.path.join(RUNTIME_DIR, "status.json")
SOCKET_PATH = os.path.join(RUNTIME_DIR, "control.sock")

# Config is the seed, never the master: it can tune numbers within clamps,
# but it cannot grant anything the daemon doesn't already do. Unknown keys
# are ignored, bad types fall back to defaults.
DEFAULTS = {
    "poll_interval": 10,       # memory moves faster than disk
    "burn_tau": 120,           # EWMA time constant for burn rate (s)
    "eta_cap_hours": 24.0,     # ETAs beyond this are noise -> omitted
    "warn_psi_some": 10.0,     # PSI some avg10 above this -> warn
    "warn_avail_pct": 15.0,
    "warn_eta_hours": 4.0,
    "hot_psi_full": 5.0,       # PSI full avg10 above this -> hot
    "hot_avail_pct": 5.0,
    "hot_eta_minutes": 30.0,
    "owner_uid": 1000,         # status/socket are chowned here when root
    "sample_every": 3,         # sampler runs every Nth poll (M2 index)
    "proc_min_bytes": 16 * 1024 * 1024,  # rss+swap floor to earn an index row
    "recent_ring": 120,        # fine-grained samples kept (~1h at defaults)
    "hourly_ring": 168,        # promoted samples kept (~7d)
    "advise_growth_mib_per_hour": 500.0,  # advise rule 2's leak-ish threshold
}

CLAMPS = {
    "poll_interval": (1, 3600),
    "burn_tau": (5, 86400),
    "eta_cap_hours": (0.1, 8760),
    "warn_psi_some": (0.0, 100.0),
    "warn_avail_pct": (0.0, 100.0),
    "warn_eta_hours": (0.01, 8760),
    "hot_psi_full": (0.0, 100.0),
    "hot_avail_pct": (0.0, 100.0),
    "hot_eta_minutes": (0.1, 525600),
    "owner_uid": (0, 2 ** 31),
    "sample_every": (1, 360),
    "proc_min_bytes": (1 << 20, 1 << 40),
    "recent_ring": (2, 100000),
    "hourly_ring": (2, 100000),
    "advise_growth_mib_per_hour": (1.0, 1000000.0),
}


def load_config(path):
    cfg = dict(DEFAULTS)
    try:
        with open(path) as f:
            raw = json.load(f)
    except (OSError, ValueError):
        return cfg
    if not isinstance(raw, dict):
        return cfg
    for key, default in DEFAULTS.items():
        if key not in raw:
            continue
        val = raw[key]
        if isinstance(default, (int, float)) and isinstance(val, (int, float)):
            lo, hi = CLAMPS[key]
            cfg[key] = type(default)(min(hi, max(lo, val)))
    return cfg


# --- polling ----------------------------------------------------------------

MEMINFO_KEYS = ("MemTotal", "MemAvailable", "SwapTotal", "SwapFree")
PSI_KEYS = ("some_avg10", "some_avg60", "some_avg300",
            "full_avg10", "full_avg60", "full_avg300")


def read_meminfo():
    vals = {}
    with open("/proc/meminfo") as f:
        for line in f:
            key, _, rest = line.partition(":")
            if key in MEMINFO_KEYS:
                vals[key] = int(rest.split()[0]) * 1024  # kB -> bytes
    return vals


def read_psi():
    psi = {k: None for k in PSI_KEYS}
    try:
        with open("/proc/pressure/memory") as f:
            lines = f.read().splitlines()
    except OSError:
        return psi  # no CONFIG_PSI — classify on meminfo alone
    for line in lines:
        parts = line.split()
        if not parts or parts[0] not in ("some", "full"):
            continue
        fields = dict(p.split("=", 1) for p in parts[1:] if "=" in p)
        for avg in ("avg10", "avg60", "avg300"):
            if avg in fields:
                try:
                    psi[f"{parts[0]}_{avg}"] = float(fields[avg])
                except ValueError:
                    pass
    return psi


def poll_memory(state, cfg, now):
    mi = read_meminfo()
    total = mi.get("MemTotal", 0)
    avail = mi.get("MemAvailable", 0)
    swap_total = mi.get("SwapTotal", 0)
    swap_free = mi.get("SwapFree", 0)
    psi = read_psi()

    prev = state.get("mem")
    ewma = 0.0
    if prev is not None:
        dt = max(1e-3, now - prev["t"])
        rate = (prev["avail"] - avail) / dt  # bytes/s, positive = being eaten
        alpha = 1.0 - math.exp(-dt / cfg["burn_tau"])
        ewma = alpha * rate + (1.0 - alpha) * prev["ewma"]
    state["mem"] = {"t": now, "avail": avail, "ewma": ewma}

    eta = None
    if ewma > 1024.0:  # below 1 KiB/s the ETA is astrology
        eta = (avail + swap_free) / ewma
        if eta > cfg["eta_cap_hours"] * 3600:
            eta = None

    return {
        "total": total,
        "available": avail,
        "swap_total": swap_total,
        "swap_free": swap_free,
        "psi": psi,
        "burn_bps": round(ewma, 1),
        "eta_oom_seconds": None if eta is None else int(eta),
        "state": classify(total, avail, psi, eta, cfg),
    }


def classify(total, avail, psi, eta, cfg):
    pct = 100.0 * avail / total if total else 0.0
    full10, some10 = psi["full_avg10"], psi["some_avg10"]
    if (full10 is not None and full10 > cfg["hot_psi_full"]) \
            or pct < cfg["hot_avail_pct"] \
            or (eta is not None and eta < cfg["hot_eta_minutes"] * 60):
        return "hot"
    if (some10 is not None and some10 > cfg["warn_psi_some"]) \
            or pct < cfg["warn_avail_pct"] \
            or (eta is not None and eta < cfg["warn_eta_hours"] * 3600):
        return "warn"
    return "ok"


def write_status(doc, cfg):
    tmp = STATUS_PATH + ".tmp"
    with open(tmp, "w") as f:
        json.dump(doc, f, separators=(",", ":"))
        f.write("\n")
    os.chmod(tmp, 0o640)
    if os.getuid() == 0:
        os.chown(tmp, cfg["owner_uid"], -1)
    os.replace(tmp, STATUS_PATH)


# --- index: the persistent truth about who's holding memory hostage --------
# One tick is one sample: pid/comm/VmRSS/VmSwap/state/ppid for every process
# at or above proc_min_bytes, keyed by (pid, starttime) — starttime (stat
# field 22) disambiguates pid reuse, the swap analogue of byebyte's path
# interning. Two rings share one promoted flag: recent_ring keeps every
# sample (~1h fine-grained), hourly_ring keeps one promoted sample per hour
# (~7d coarse) — `top`/`swap` read the latest sample, `blame` diffs two.
# The sampler runs synchronously in the poll loop (a /proc pass is cheap,
# unlike byebyte's disk walk, so it never needs its own thread); every query
# opens its own short-lived read connection, so a `top` never blocks a tick.

STATE_DIR = os.environ.get("RAMSTEIN_STATE_DIR", "/var/lib/ramstein")
DB_PATH = os.path.join(STATE_DIR, "index.db")

_SCHEMA = """
CREATE TABLE IF NOT EXISTS samples(
    id INTEGER PRIMARY KEY,
    ts REAL NOT NULL,
    promoted INTEGER NOT NULL DEFAULT 0);
CREATE TABLE IF NOT EXISTS proc_stats(
    sample_id INTEGER NOT NULL,
    pid INTEGER NOT NULL,
    starttime INTEGER NOT NULL,
    comm TEXT NOT NULL,
    rss INTEGER NOT NULL,
    swap INTEGER NOT NULL,
    state TEXT NOT NULL,
    ppid INTEGER NOT NULL,
    PRIMARY KEY(sample_id, pid, starttime)) WITHOUT ROWID;
"""


def _connect_index():
    os.makedirs(STATE_DIR, exist_ok=True)
    con = sqlite3.connect(DB_PATH, timeout=30)
    con.execute("PRAGMA journal_mode=WAL")
    return con


def _read_procs():
    """One pass over /proc: pid/comm/rss/swap/state/ppid/starttime for every
    process with a VmRSS line. Kernel threads (no VmRSS — no memory mappings)
    and unreadable pids (other users, or a pid that exited mid-scan) are
    skipped silently; as root this sees all."""
    for entry in os.scandir("/proc"):
        if not entry.name.isdigit():
            continue
        pid = int(entry.name)
        try:
            with open(f"/proc/{pid}/status") as f:
                status = f.read()
        except OSError:
            continue
        if "VmRSS" not in status:
            continue  # kernel thread
        comm = state = None
        ppid = rss = swap = 0
        for line in status.splitlines():
            key, _, rest = line.partition(":")
            if key == "Name":
                comm = rest.strip()
            elif key == "State":
                state = rest.strip().split()[0]
            elif key == "PPid":
                ppid = int(rest.strip())
            elif key == "VmRSS":
                rss = int(rest.split()[0]) * 1024
            elif key == "VmSwap":
                swap = int(rest.split()[0]) * 1024
        try:
            with open(f"/proc/{pid}/stat") as f:
                stat = f.read()
        except OSError:
            continue
        # comm is parenthesized and may itself contain ')' or spaces; split
        # on the LAST ')' so the fixed-format fields after it stay aligned.
        # what follows is field 3 (state) onward, so field 22 (starttime,
        # 1-indexed) sits at offset 22-3=19 in the split remainder.
        rest_fields = stat[stat.rfind(")") + 2:].split()
        try:
            starttime = int(rest_fields[19])
        except (IndexError, ValueError):
            continue
        yield {"pid": pid, "comm": comm or "?", "rss": rss, "swap": swap,
               "state": state or "?", "ppid": ppid, "starttime": starttime}


class Sampler:
    def __init__(self, cfg):
        self.cfg = cfg
        self._tick = 0
        self._last_promoted_ts = None
        self.last_sample_ts = None
        con = _connect_index()
        try:
            con.executescript(_SCHEMA)
            con.commit()
        finally:
            con.close()

    def maybe_sample(self, now):
        self._tick += 1
        if self._tick % self.cfg["sample_every"]:
            return False
        self._sample(now)
        return True

    def _sample(self, now):
        floor = self.cfg["proc_min_bytes"]
        procs = [p for p in _read_procs() if p["rss"] + p["swap"] >= floor]
        promote = (self._last_promoted_ts is None
                   or now - self._last_promoted_ts >= 3600)
        con = _connect_index()
        try:
            cur = con.execute(
                "INSERT INTO samples(ts, promoted) VALUES(?,?)",
                (now, int(promote)))
            sid = cur.lastrowid
            con.executemany(
                "INSERT INTO proc_stats VALUES(?,?,?,?,?,?,?,?)",
                [(sid, p["pid"], p["starttime"], p["comm"], p["rss"],
                  p["swap"], p["state"], p["ppid"]) for p in procs])
            self._prune(con)
            con.commit()
        finally:
            con.close()
        if promote:
            self._last_promoted_ts = now
        self.last_sample_ts = now

    def _prune(self, con):
        keep = {r[0] for r in con.execute(
            "SELECT id FROM samples ORDER BY ts DESC LIMIT ?",
            (self.cfg["recent_ring"],))}
        keep |= {r[0] for r in con.execute(
            "SELECT id FROM samples WHERE promoted=1 ORDER BY ts DESC LIMIT ?",
            (self.cfg["hourly_ring"],))}
        stale = [r[0] for r in con.execute("SELECT id FROM samples")
                 if r[0] not in keep]
        if stale:
            marks = ",".join("?" * len(stale))
            con.execute(f"DELETE FROM proc_stats WHERE sample_id IN ({marks})",
                        stale)
            con.execute(f"DELETE FROM samples WHERE id IN ({marks})", stale)


def _latest_sample(con):
    return con.execute(
        "SELECT id, ts FROM samples ORDER BY ts DESC LIMIT 1").fetchone()


def query_top(by_swap, limit):
    con = _connect_index()
    try:
        latest = _latest_sample(con)
        if latest is None:
            return {"error": "no sample yet — wait for the sampler"}
        sid, ts = latest
        col = "swap" if by_swap else "rss"  # by_swap is a validated bool
        rows = con.execute(
            f"SELECT pid, comm, rss, swap, state FROM proc_stats"
            f" WHERE sample_id=? ORDER BY {col} DESC LIMIT ?", (sid, limit)
        ).fetchall()
        return {"ts": ts, "rows": [
            {"pid": r[0], "comm": r[1], "rss": r[2], "swap": r[3],
             "state": r[4]} for r in rows]}
    finally:
        con.close()


def query_swap(limit):
    con = _connect_index()
    try:
        latest = _latest_sample(con)
        if latest is None:
            return {"error": "no sample yet — wait for the sampler"}
        sid, ts = latest
        rows = con.execute(
            "SELECT pid, comm, rss, swap, state FROM proc_stats"
            " WHERE sample_id=? AND swap > 0 ORDER BY swap DESC LIMIT ?",
            (sid, limit)).fetchall()
        return {"ts": ts, "rows": [
            {"pid": r[0], "comm": r[1], "rss": r[2], "swap": r[3],
             "state": r[4]} for r in rows]}
    finally:
        con.close()


def query_blame(since, limit):
    con = _connect_index()
    try:
        head = _latest_sample(con)
        if head is None:
            return {"error": "no sample yet — wait for the sampler"}
        head_id, head_ts = head
        base = con.execute(
            "SELECT id, ts FROM samples WHERE ts <= ? ORDER BY ts DESC LIMIT 1",
            (since,)).fetchone()
        if base is None:
            # every sample is newer than --since: diff from the oldest one we
            # have and report the honest span, rather than refusing
            base = con.execute(
                "SELECT id, ts FROM samples ORDER BY ts ASC LIMIT 1").fetchone()
        if base is None or base[0] == head_id:
            return {"error": "no earlier sample to diff against"
                             " — need two samples spanning --since"}
        base_id, base_ts = base
        rows = con.execute(
            "SELECT h.pid, h.starttime, h.comm,"
            "       h.rss - COALESCE(b.rss, 0) AS delta, h.rss, h.swap,"
            "       CASE WHEN b.rss IS NULL THEN 1 ELSE 0 END, 0"
            " FROM proc_stats h LEFT JOIN proc_stats b"
            "   ON b.sample_id=? AND b.pid=h.pid AND b.starttime=h.starttime"
            " WHERE h.sample_id=?"
            " UNION ALL "
            "SELECT b.pid, b.starttime, b.comm, -b.rss, 0, 0, 0, 1"
            " FROM proc_stats b WHERE b.sample_id=? AND NOT EXISTS ("
            "   SELECT 1 FROM proc_stats h WHERE h.sample_id=?"
            "     AND h.pid=b.pid AND h.starttime=b.starttime)",
            (base_id, head_id, base_id, head_id)).fetchall()
        rows.sort(key=lambda r: (-abs(r[3]), 0 if r[3] >= 0 else 1))
        rows = rows[:limit]
        return {"base_ts": base_ts, "head_ts": head_ts, "rows": [
            {"pid": r[0], "starttime": r[1], "comm": r[2], "delta": r[3],
             "rss": r[4], "swap": r[5], "new": bool(r[6]), "gone": bool(r[7])}
            for r in rows]}
    finally:
        con.close()


def query_zombies():
    rows = []
    for entry in os.scandir("/proc"):
        if not entry.name.isdigit():
            continue
        pid = int(entry.name)
        try:
            with open(f"/proc/{pid}/status") as f:
                status = f.read()
        except OSError:
            continue
        comm = state = None
        ppid = 0
        for line in status.splitlines():
            key, _, rest = line.partition(":")
            if key == "Name":
                comm = rest.strip()
            elif key == "State":
                state = rest.strip().split()[0]
            elif key == "PPid":
                ppid = int(rest.strip())
        if state != "Z":
            continue
        parent_comm = "?"
        try:
            with open(f"/proc/{ppid}/status") as f:
                for line in f:
                    if line.startswith("Name:"):
                        parent_comm = line.partition(":")[2].strip()
                        break
        except OSError:
            pass
        rows.append({"pid": pid, "comm": comm or "?", "ppid": ppid,
                     "parent_comm": parent_comm})
    return {"rows": rows}


def _limit(req):
    lim = req.get("limit", 20)
    if not isinstance(lim, int) or not 1 <= lim <= 1000:
        raise ValueError("limit must be an int in 1..1000")
    return lim


# --- hands: calm / oom / advise (M3) ----------------------------------------
# The invariant gates come first, on purpose (M3-SPEC.md): coexistence with
# systemd-oomd/earlyoom, and the kill gate. The CLI gates the HUMAN (fresh
# per-invocation TTY confirmation); the daemon gates the SYSCALL (re-resolves
# pid+starttime itself — never trusts that what the CLI resolved earlier is
# still true by the time the command arrives). Ledgered to
# STATE_DIR/ledger.jsonl, the family ledger, memory dialect.

CALM_HIGH_FLOOR_BYTES = 64 * 1024 * 1024  # PLAN.md Invariant #2's floor
NICE_MIN, NICE_MAX = 0, 19                # calm only ever LOWERS priority
LEDGER_PATH = os.path.join(STATE_DIR, "ledger.jsonl")


def _coexisting_oom_fighter():
    """Read-only: is systemd-oomd or earlyoom already fighting OOM here?"""
    for unit in ("systemd-oomd", "earlyoom"):
        try:
            r = subprocess.run(["systemctl", "is-active", unit],
                               capture_output=True, text=True, timeout=2)
        except (OSError, subprocess.SubprocessError):
            continue
        if r.stdout.strip() == "active":
            return unit
    return None


def _ledger_write(entry):
    os.makedirs(STATE_DIR, exist_ok=True)
    with open(LEDGER_PATH, "a") as f:
        f.write(json.dumps(entry, separators=(",", ":")) + "\n")


def _cgroup_root():
    # An env override is honored ONLY when running unprivileged — a root
    # daemon must never let an environment variable redirect where it writes
    # real cgroup files (config-can't-weaken-safety doctrine, applied to
    # env). Tests run as an unprivileged user and use this to point at a
    # fake, writable cgroup tree instead of the real, unwritable one.
    root = os.environ.get("RAMSTEIN_CGROUP_ROOT")
    if root and os.getuid() != 0:
        return root
    return "/sys/fs/cgroup"


def _cgroup_path(pid):
    try:
        with open(f"/proc/{pid}/cgroup") as f:
            lines = f.read().splitlines()
    except OSError:
        return None
    for line in lines:
        parts = line.split(":", 2)
        if len(parts) == 3 and parts[0] == "0":  # cgroup v2 unified line
            return os.path.join(_cgroup_root(), parts[2].lstrip("/"))
    return None


def _mem_total_bytes():
    with open("/proc/meminfo") as f:
        for line in f:
            if line.startswith("MemTotal"):
                return int(line.split()[1]) * 1024
    return 0


def _parse_size(text):
    """'500M' / '2G' / 'max' -> bytes (None for 'max'). Raises on garbage
    or a non-positive size — hostile input, never silently clamped up."""
    if text == "max":
        return None
    units = {"K": 1024, "M": 1024 ** 2, "G": 1024 ** 3}
    unit = text[-1].upper() if text else ""
    try:
        n = float(text[:-1]) if unit in units else float(text)
    except ValueError:
        raise ValueError("bad size")
    value = n * units.get(unit, 1)
    if value <= 0:
        raise ValueError("size must be positive")
    return int(value)


def _find_proc(pid):
    return next((p for p in _read_procs() if p["pid"] == pid), None)


def query_resolve(target):
    """pid (as int or digit-string) matches by pid; anything else matches by
    exact comm — which, same as `ps`, is routinely NOT unique (multiple
    chrome/postgres/python processes), hence the caller must handle >1."""
    if isinstance(target, int) or (isinstance(target, str) and target.isdigit()):
        pid = int(target)
        matches = [p for p in _read_procs() if p["pid"] == pid]
    else:
        matches = [p for p in _read_procs() if p["comm"] == target]
    return {"matches": [
        {"pid": p["pid"], "comm": p["comm"], "rss": p["rss"], "swap": p["swap"],
         "starttime": p["starttime"]} for p in matches]}


def query_oom(get_status):
    doc = get_status()
    mem = doc.get("memory") if isinstance(doc, dict) else None
    candidates = []
    for entry in os.scandir("/proc"):
        if not entry.name.isdigit():
            continue
        pid = int(entry.name)
        try:
            with open(f"/proc/{pid}/oom_score") as f:
                score = int(f.read().strip())
        except (OSError, ValueError):
            continue
        try:
            with open(f"/proc/{pid}/status") as f:
                status = f.read()
        except OSError:
            continue
        if "VmRSS" not in status:
            continue
        comm, rss = None, 0
        for line in status.splitlines():
            key, _, rest = line.partition(":")
            if key == "Name":
                comm = rest.strip()
            elif key == "VmRSS":
                rss = int(rest.split()[0]) * 1024
        candidates.append({"pid": pid, "comm": comm or "?", "rss": rss,
                           "oom_score": score})
    candidates.sort(key=lambda c: c["oom_score"], reverse=True)
    return {"memory": mem, "candidates": candidates[:5]}


def query_advise(cfg, get_status):
    lines = []
    doc = get_status()
    mem = doc.get("memory") if isinstance(doc, dict) else None

    # rule 1: sustained pressure (avg60, not the twitchier avg10)
    if mem:
        some60 = mem["psi"].get("some_avg60")
        if some60 is not None and some60 > cfg["warn_psi_some"]:
            lines.append({"rule": "psi", "text":
                f"sustained pressure: PSI some avg60 {some60:.1f}%"
                f" > {cfg['warn_psi_some']:.1f}%"})

    # rule 2: top RSS grower over the recent ring (~1h), MiB/h rate
    con = _connect_index()
    try:
        head = _latest_sample(con)
        if head is not None:
            head_id, head_ts = head
            base = con.execute(
                "SELECT id, ts FROM samples WHERE ts <= ?"
                " ORDER BY ts DESC LIMIT 1", (head_ts - 3600,)).fetchone()
            if base is None:
                base = con.execute(
                    "SELECT id, ts FROM samples ORDER BY ts ASC LIMIT 1"
                ).fetchone()
            if base and base[0] != head_id:
                base_id, base_ts = base
                row = con.execute(
                    "SELECT h.pid, h.comm, h.rss - COALESCE(b.rss, 0)"
                    " FROM proc_stats h LEFT JOIN proc_stats b"
                    "   ON b.sample_id=? AND b.pid=h.pid"
                    "     AND b.starttime=h.starttime"
                    " WHERE h.sample_id=? ORDER BY 3 DESC LIMIT 1",
                    (base_id, head_id)).fetchone()
                span_s = (head_ts - base_ts) if row else 0
                # a short span extrapolated to an hourly rate is noise, not
                # signal — require at least 5 minutes of real history before
                # this rule speaks (freshly started daemon, thin ring, etc.)
                if row and span_s >= 300:
                    pid, comm, delta = row
                    rate = delta / (span_s / 3600.0)
                    threshold = cfg["advise_growth_mib_per_hour"] * 1024 ** 2
                    if rate > threshold:
                        lines.append({"rule": "growth", "text":
                            f"{comm} (pid {pid}) growing"
                            f" ~{rate / 1024 / 1024:.0f} MiB/h"})
    finally:
        con.close()

    # rule 3: swap occupancy > 50%, name the top tenant
    if mem and mem.get("swap_total", 0) > 0:
        used_pct = (100.0 * (mem["swap_total"] - mem["swap_free"])
                    / mem["swap_total"])
        if used_pct > 50.0:
            top = query_swap(1)
            tenant = (top.get("rows") or [None])[0]
            if tenant:
                lines.append({"rule": "swap", "text":
                    f"swap {used_pct:.0f}% full — top tenant {tenant['comm']}"
                    f" (pid {tenant['pid']}, {tenant['swap']}B)"})

    # rule 4: zombies, name the parent not reaping them
    zs = query_zombies()["rows"]
    if zs:
        tally = {}
        for z in zs:
            tally[z["parent_comm"]] = tally.get(z["parent_comm"], 0) + 1
        parent, count = max(tally.items(), key=lambda kv: kv[1])
        lines.append({"rule": "zombies", "text":
            f"{len(zs)} zombie(s) unreaped — {parent} isn't reaping"
            f" ({count} of them)"})

    # rule 5: another OOM-fighter active — stand-down language
    fighter = _coexisting_oom_fighter()
    if fighter:
        lines.append({"rule": "coexist", "text":
            f"{fighter} is active — RAMstein's kill prompts stay"
            " advisory-only, standing down"})

    # rule 6: ETA under an hour — point at `oom`
    if mem:
        eta = mem.get("eta_oom_seconds")
        if eta is not None and eta < 3600:
            lines.append({"rule": "eta", "text":
                f"OOM ETA {eta}s — see `ramstein oom` for kill candidates"})

    return {"lines": lines}


def build_pill_summary(cfg, get_status):
    """A compact M2/M3 digest embedded into status.json so the pill stays a
    one-file reader (GFileMonitor on status.json, no socket client in GJS)
    instead of growing its own daemon-protocol client. Computed on the
    sampler's own cadence (maybe_sample's return value), not every poll
    tick — advise's coexistence check spawns systemctl, and there is no
    reason to pay that cost 3x more often than the index itself refreshes."""
    con = _connect_index()
    try:
        top_process = None
        latest = _latest_sample(con)
        if latest is not None:
            sid, _ts = latest
            row = con.execute(
                "SELECT pid, comm, rss FROM proc_stats WHERE sample_id=?"
                " ORDER BY rss DESC LIMIT 1", (sid,)).fetchone()
            if row:
                top_process = {"pid": row[0], "comm": row[1], "rss": row[2]}
    finally:
        con.close()
    zombie_count = len(query_zombies()["rows"])
    advise = query_advise(cfg, get_status)
    lines = advise["lines"]
    return {
        "top_process": top_process,
        "zombie_count": zombie_count,
        "advise_headline": lines[0]["text"] if lines else None,
        "advise_count": len(lines),
    }


def do_calm(pid, starttime, action, size=None, nice=None):
    proc = _find_proc(pid)
    if proc is None:
        return {"error": "target process not found"}
    if proc["starttime"] != starttime:
        return {"error": "stale pid — starttime mismatch, refusing"}

    result = {"pid": pid, "comm": proc["comm"]}
    fighter = _coexisting_oom_fighter()
    if fighter:
        result["coexist_warning"] = fighter

    if action == "nice":
        try:
            os.setpriority(os.PRIO_PROCESS, pid, nice)
        except OSError as exc:
            return {"error": f"renice failed: {exc.strerror}"}
        result.update(ok=True, nice=nice)
        _ledger_write({"ts": time.time(), "verb": "calm", "pid": pid,
                       "comm": proc["comm"], "arg": f"nice={nice}",
                       "result": "ok"})
        return result

    # high / release both write memory.high
    cpath = _cgroup_path(pid)
    high_file = os.path.join(cpath, "memory.high") if cpath else None
    if not high_file or not os.access(high_file, os.W_OK):
        return {"error": "cgroup memory.high not writable — try --nice"}
    if action == "release":
        write_val, value_bytes = "max", None
    else:
        requested = _parse_size(size)
        if requested is None:
            write_val, value_bytes = "max", None
        else:
            # PLAN.md Invariant #2: the floor is computed from the target's
            # OWN rss, so a tampered/fat-fingered SIZE can never be set low
            # enough to instant-thrash-OOM the thing calm is meant to help.
            floor = max(CALM_HIGH_FLOOR_BYTES, int(proc["rss"] * 1.1))
            clamped = max(floor, min(requested, _mem_total_bytes()))
            write_val, value_bytes = str(clamped), clamped
    try:
        with open(high_file, "w") as f:
            f.write(write_val)
    except OSError as exc:
        return {"error": f"write failed: {exc.strerror}"}
    result.update(ok=True, cgroup=cpath, memory_high=value_bytes)
    _ledger_write({"ts": time.time(), "verb": "calm", "pid": pid,
                   "comm": proc["comm"],
                   "arg": "release" if action == "release" else size,
                   "result": "ok"})
    return result


def do_kill(pid, starttime, confirm, sig):
    # invariant gates: confirm must echo pid (defense in depth against a
    # caller that sends pid without ever having gone through a real confirm
    # step), and pid 1 / the daemon's own pid are never valid — kernel
    # threads are already structurally excluded, _find_proc can't see them
    # (no VmRSS -> _read_procs skips them).
    if confirm != pid:
        return {"error": "confirm must equal pid"}
    if pid in (1, os.getpid()):
        return {"error": "refused: protected pid"}
    proc = _find_proc(pid)
    if proc is None:
        return {"error": "target process not found"}
    if proc["starttime"] != starttime:
        return {"error": "stale pid — starttime mismatch, refusing"}
    fighter = _coexisting_oom_fighter()
    real_sig = signal.SIGKILL if sig == "KILL" else signal.SIGTERM
    try:
        os.kill(pid, real_sig)
    except OSError as exc:
        return {"error": f"kill failed: {exc.strerror}"}
    result = {"ok": True, "pid": pid, "comm": proc["comm"], "signal": sig}
    if fighter:
        result["coexist_warning"] = fighter
    _ledger_write({"ts": time.time(), "verb": "kill", "pid": pid,
                   "comm": proc["comm"], "arg": sig, "result": "ok"})
    return result


# --- control socket ---------------------------------------------------------
# Input is hostile by default: SO_PEERCRED-gated (root or the owner, on top
# of the 0660 file mode — family ruling 2026-07-14), bounded reads, JSON
# only, a fixed command set, anything else answers {"error": ...} and the
# connection dies.

class Control(threading.Thread):
    MAX_LINE = 4096

    def __init__(self, cfg, get_status):
        super().__init__(daemon=True)
        self.cfg = cfg
        self.get_status = get_status
        self._allowed = {0, os.getuid(), cfg["owner_uid"]}
        try:
            os.unlink(SOCKET_PATH)
        except FileNotFoundError:
            pass
        self.srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        self.srv.bind(SOCKET_PATH)
        os.chmod(SOCKET_PATH, 0o660)
        if os.getuid() == 0:
            os.chown(SOCKET_PATH, cfg["owner_uid"], -1)
        # a deep-ish backlog so a burst of rapid connects is absorbed by the
        # kernel queue instead of bouncing clients with EAGAIN — M4's attack
        # suite (rapid-reconnect phase) found listen(4) too small under a
        # 200-connection burst; the accept loop itself was never the
        # bottleneck (each connection already hands off to its own thread)
        self.srv.listen(64)

    def run(self):
        while True:
            try:
                conn, _ = self.srv.accept()
            except OSError:
                return
            threading.Thread(target=self.handle, args=(conn,),
                             daemon=True).start()

    def handle(self, conn):
        try:
            creds = conn.getsockopt(socket.SOL_SOCKET, socket.SO_PEERCRED,
                                    struct.calcsize("3i"))
            _pid, peer_uid, _gid = struct.unpack("3i", creds)
            if peer_uid not in self._allowed:
                raise PermissionError("peer not allowed")
            conn.settimeout(5)
            data = b""
            while b"\n" not in data:
                chunk = conn.recv(1024)
                if not chunk:
                    break
                data += chunk
                if len(data) > self.MAX_LINE:
                    raise ValueError("line too long")
            req = json.loads(data.decode("utf-8").splitlines()[0] or "{}")
            if not isinstance(req, dict):
                raise ValueError("not an object")
            cmd = req.get("cmd")
            if cmd == "ping":
                resp = {"ok": True, "version": VERSION}
            elif cmd == "status":
                resp = self.get_status()
            elif cmd == "top":
                by_swap = req.get("swap", False)
                if not isinstance(by_swap, bool):
                    raise ValueError("swap must be a bool")
                resp = query_top(by_swap, _limit(req))
            elif cmd == "swap":
                resp = query_swap(_limit(req))
            elif cmd == "blame":
                since = req.get("since")
                if not isinstance(since, (int, float)) or since <= 0:
                    raise ValueError("since must be a positive epoch timestamp")
                resp = query_blame(float(since), _limit(req))
            elif cmd == "zombies":
                resp = query_zombies()
            elif cmd == "resolve":
                target = req.get("target")
                if not isinstance(target, str) or not target:
                    raise ValueError("target must be a non-empty string")
                resp = query_resolve(target)
            elif cmd == "oom":
                resp = query_oom(self.get_status)
            elif cmd == "advise":
                resp = query_advise(self.cfg, self.get_status)
            elif cmd == "calm":
                pid = req.get("pid")
                starttime = req.get("starttime")
                action = req.get("action")
                if not isinstance(pid, int) or not isinstance(starttime, int):
                    raise ValueError("pid/starttime must be ints")
                if action == "high":
                    size = req.get("size")
                    if not isinstance(size, str) or not size:
                        raise ValueError("size must be a non-empty string")
                    resp = do_calm(pid, starttime, "high", size=size)
                elif action == "release":
                    resp = do_calm(pid, starttime, "release")
                elif action == "nice":
                    nice = req.get("nice")
                    if not isinstance(nice, int) or not NICE_MIN <= nice <= NICE_MAX:
                        raise ValueError(
                            f"nice must be an int in {NICE_MIN}..{NICE_MAX}")
                    resp = do_calm(pid, starttime, "nice", nice=nice)
                else:
                    raise ValueError("unknown calm action")
            elif cmd == "kill":
                pid = req.get("pid")
                starttime = req.get("starttime")
                confirm = req.get("confirm")
                sig = req.get("sig", "TERM")
                if not isinstance(pid, int) or not isinstance(starttime, int) \
                        or not isinstance(confirm, int):
                    raise ValueError("pid/starttime/confirm must be ints")
                if sig not in ("TERM", "KILL"):
                    raise ValueError("sig must be TERM or KILL")
                resp = do_kill(pid, starttime, confirm, sig)
            else:
                resp = {"error": "unknown command"}
        except Exception as exc:  # noqa: BLE001 — hostile input, never crash
            resp = {"error": type(exc).__name__}
        try:
            conn.sendall((json.dumps(resp, separators=(",", ":")) + "\n")
                         .encode())
        except OSError:
            pass
        finally:
            conn.close()


# --- main -------------------------------------------------------------------

def main():
    ap = argparse.ArgumentParser(prog="ramsteind")
    ap.add_argument("--config", default="/etc/ramstein/config.json")
    ap.add_argument("--once", action="store_true",
                    help="single poll, write status, exit")
    args = ap.parse_args()

    cfg = load_config(args.config)
    os.makedirs(RUNTIME_DIR, exist_ok=True)

    stop = threading.Event()
    for sig in (signal.SIGTERM, signal.SIGINT):
        signal.signal(sig, lambda *_: stop.set())

    state = {}
    latest = {"doc": {"error": "no status yet"}}
    pill_cache = {"summary": None}
    sampler = Sampler(cfg)
    ctl = Control(cfg, lambda: latest["doc"])
    ctl.start()

    while not stop.is_set():
        now = time.time()
        doc = {
            "v": 1,
            "ts": now,
            "daemon": {"version": VERSION, "pid": os.getpid(),
                       "poll_interval": cfg["poll_interval"]},
            "memory": poll_memory(state, cfg, now),
        }
        latest["doc"] = doc
        # pill summary refreshes on the sampler's own cadence (not every
        # tick — see build_pill_summary), reusing the last one otherwise
        if sampler.maybe_sample(now):
            pill_cache["summary"] = build_pill_summary(cfg, lambda: latest["doc"])
        doc["pill"] = pill_cache["summary"]
        latest["doc"] = doc
        write_status(doc, cfg)
        if args.once:
            break
        stop.wait(cfg["poll_interval"])


if __name__ == "__main__":
    main()

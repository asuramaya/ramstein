#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-or-later
# Copyright (C) 2026 asuramaya and RAMstein contributors
"""ramstein-update — check GitHub for newer RAMstein releases.

Family doctrine: updates are click-to-install, never unattended. The daily
ramstein-update.timer runs this with --check, which only CHECKS and prints —
it never installs. And in this version even the interactive path is an
explicit stub: RAMstein has no published releases yet, so there is nothing
verifiable to download, and the family rule is fail-closed — never install
what can't be verified. When releases exist, installing inherits the
phanspeed model wholesale (fail-closed SHA256SUMS, signature verification
once a key is provisioned). Until then this program never installs anything.

This is deliberately a SEPARATE program from the daemon: ramsteind never
touches the network, so the one component that reaches the internet is this
small, unprivileged checker — never the privileged poller.

  ramstein-update --check          human one-liner, exit 0 either way
  ramstein-update --check --json   {"available": ..., "latest": ..., "current": ...}
"""
import json
import os
import re
import sys
import urllib.error
import urllib.request

REPO = "asuramaya/RAMstein"
API = f"https://api.github.com/repos/{REPO}/releases/latest"
# Installed marker first (written by install.sh), falling back to the
# repo-relative VERSION for a source checkout / dev testing.
_SRC_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
VERSION_CANDIDATES = (
    "/usr/local/share/ramstein/VERSION",
    os.path.join(_SRC_DIR, "VERSION"),
)


def installed_version():
    for path in VERSION_CANDIDATES:
        try:
            with open(path) as f:
                v = f.read().strip()
        except OSError:
            continue
        if v:
            return v
    return None


def vtuple(v):
    return tuple(int(x) for x in re.findall(r"\d+", v or "")[:3])


def fetch(url, timeout=20, max_bytes=1024 * 1024):
    # Cap the body so a compromised/MITM'd endpoint can't balloon the checker's
    # memory. Release metadata is a few KB; 1 MiB is generous. Read
    # max_bytes+1 and reject if the response would exceed the cap.
    req = urllib.request.Request(url, headers={"User-Agent": "ramstein-update"})
    with urllib.request.urlopen(req, timeout=timeout) as r:  # noqa: S310 (https)
        data = r.read(max_bytes + 1)
    if len(data) > max_bytes:
        raise ValueError("response too large")
    return data.decode()


def main():
    json_out = "--json" in sys.argv
    check_only = "--check" in sys.argv or json_out  # --json implies check-only
    cur = installed_version()

    def emit(available, latest=None, note=None):
        if json_out:
            print(json.dumps({"available": bool(available), "latest": latest,
                              "current": cur}))
        elif note:
            print(note)

    try:
        rel = json.loads(fetch(API))
    except urllib.error.HTTPError as e:
        if e.code == 404:
            # Graceful, not an error: the repo simply has no releases yet.
            emit(False, note="no RAMstein releases published yet "
                             f"(installed {cur or 'unknown'}); nothing to do.")
            return 0
        emit(False, note=f"update check failed (HTTP {e.code}).")
        return 0
    except Exception as e:
        emit(False, note=f"update check failed (offline?): {e}")
        return 0
    tag = (rel.get("tag_name") or "").lstrip("v")
    if not tag:
        emit(False, note="no release tag found.")
        return 0
    if cur is not None and vtuple(tag) <= vtuple(cur):
        emit(False, latest=tag, note=f"up to date (installed {cur}, latest {tag}).")
        return 0

    emit(True, latest=tag, note=f"update available: {cur or 'unknown'} -> {tag}")
    if check_only:
        return 0

    # ---- install path: an EXPLICIT STUB, on purpose -------------------------
    # No release pipeline exists yet, so there are no checksummed assets to
    # verify against — and fail-closed means refusing, not improvising. This
    # version never installs anything; when the first release ships this grows
    # the phanspeed flow (download, verify SHA256SUMS, verify the signature
    # once a key is provisioned, install) — still only ever from a deliberate,
    # interactive invocation, never from the timer.
    print("installing from here is not wired yet (no verifiable release assets"
          " exist). Update from a checkout instead:\n"
          "  git pull && sudo ./install.sh")
    return 1


if __name__ == "__main__":
    sys.exit(main())
